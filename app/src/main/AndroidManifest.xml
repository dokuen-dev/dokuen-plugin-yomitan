<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <queries>
        <package android:name="io.github.dokuendev.dokuenreader" />
    </queries>

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Material3.DayNight.NoActionBar">

        <activity
            android:name=".MainActivity"
            android:configChanges="orientation|screenSize|screenLayout|smallestScreenSize"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".YomitanDictionaryPluginService"
            android:exported="true">
            <intent-filter>
                <action android:name="io.github.dokuendev.dokuenreader.dictionary.BIND_DICTIONARY_SERVICE" />
                <category android:name="io.github.dokuendev.dokuenreader.category.DICTIONARY" />
            </intent-filter>

            <!-- REQUIRED: These five fields are mandatory -->
            <meta-data
                android:name="plugin_name"
                android:value="Yomitan" />
            <meta-data
                android:name="plugin_version"
                android:value="1.0.0" />
            <meta-data
                android:name="plugin_author"
                android:value="Dokuen Reader" />
            <meta-data
                android:name="plugin_description"
                android:value="Dokuen port of the popular Yomitan browser extension." />
            <meta-data
                android:name="plugin_license"
                android:value="GPL 3.0" />

            <!-- Optional metadata -->
            <meta-data
                android:name="plugin_website"
                android:value="https://github.com/dokuen-dev/dokuen-plugin-yomitan" />
            <meta-data
                android:name="plugin_support_email"
                android:value="dokuen.reader@gmail.com" />
        </service>
    </application>

</manifest>

